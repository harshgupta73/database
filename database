/

SELECT
u.full_name,
p.plan_name,
s.start_date,
s.end_date,
s.status
FROM USERS u
JOIN USER_SUBSCRIPTIONS s
ON u.user_id = s.user_id
JOIN SUBSCRIPTION_PLANS p
ON s.plan_id = p.plan_id;


SELECT
u.full_name,
s.status
FROM USERS u
JOIN USER_SUBSCRIPTIONS s
ON u.user_id = s.user_id
WHERE s.status='ACTIVE';


SELECT
plan_id,
COUNT(user_id) AS total_users
FROM USER_SUBSCRIPTIONS
GROUP BY plan_id;


SELECT
plan_id,
COUNT(user_id) AS total_users
FROM USER_SUBSCRIPTIONS
GROUP BY plan_id
HAVING COUNT(user_id) > 10;

CREATE OR REPLACE FUNCTION check_subscription_status(
    p_subscription_id IN INT
)
RETURN VARCHAR2
IS
    result VARCHAR2(20);
BEGIN
    SELECT status
    INTO result
    FROM USER_SUBSCRIPTIONS
    WHERE subscription_id = p_subscription_id;

    RETURN result;
END;
/

SELECT check_subscription_status(1) FROM dual;


