CREATE OR REPLACE PROCEDURE record_payment(
    p_payment_id IN INT,
    p_user_id IN INT,
    p_subscription_id IN INT,
    p_amount IN NUMBER,
    p_payment_method IN VARCHAR2
)
IS
BEGIN
    INSERT INTO PAYMENTS
    VALUES(
        p_payment_id,
        p_user_id,
        p_subscription_id,
        p_amount,
        p_payment_method,
        'SUCCESS',
        SYSDATE
    );

    DBMS_OUTPUT.PUT_LINE('Payment Recorded');
END;
/


BEGIN
    record_payment(
        1,
        1,
        1,
        499,
        'UPI'
    );
END;
/


SELECT
p.payment_id,
u.full_name,
p.amount,
p.payment_method
FROM PAYMENTS p
JOIN USERS u
ON p.user_id = u.user_id;


SELECT
SUM(amount) AS total_revenue
FROM PAYMENTS;


SELECT
s.plan_id,
SUM(p.amount) AS revenue
FROM PAYMENTS p
JOIN USER_SUBSCRIPTIONS s
ON p.subscription_id = s.subscription_id
GROUP BY s.plan_id;


SELECT *
FROM PAYMENTS
WHERE amount >
(
    SELECT AVG(amount)
    FROM PAYMENTS
);


CREATE OR REPLACE VIEW high_rated_content_view AS
SELECT *
FROM CONTENT
WHERE rating > 8;


CREATE OR REPLACE VIEW user_subscription_details_view AS
SELECT
u.full_name,
p.plan_name,
s.start_date,
s.end_date,
s.status
FROM USERS u
JOIN USER_SUBSCRIPTIONS s
ON u.user_id = s.user_id
JOIN SUBSCRIPTION_PLANS p
ON s.plan_id = p.plan_id;


CREATE OR REPLACE VIEW revenue_summary_view AS
SELECT
payment_method,
SUM(amount) AS total_revenue
FROM PAYMENTS
GROUP BY payment_method;



CREATE OR REPLACE FUNCTION get_total_revenue
RETURN NUMBER
IS
    total NUMBER;
BEGIN
    SELECT SUM(amount)
    INTO total
    FROM PAYMENTS;

    RETURN total;
END;
/


CREATE OR REPLACE FUNCTION count_subscriptions(
    p_user_id IN INT
)
RETURN NUMBER
IS
    total NUMBER;
BEGIN
    SELECT COUNT(*)
    INTO total
    FROM USER_SUBSCRIPTIONS
    WHERE user_id = p_user_id;

    RETURN total;
END;
/

CREATE OR REPLACE FUNCTION get_total_views(
    p_content_id IN INT
)
RETURN NUMBER
IS
    total NUMBER;
BEGIN
    SELECT COUNT(*)
    INTO total
    FROM WATCH_HISTORY
    WHERE content_id = p_content_id;

    RETURN total;
END;
/


SELECT get_total_revenue
FROM dual;


SELECT count_subscriptions(1)
FROM dual;

SELECT get_total_views(1)
FROM dual;


CREATE OR REPLACE PROCEDURE cancel_subscription(
    p_subscription_id IN INT
)
IS
BEGIN
    UPDATE USER_SUBSCRIPTIONS
    SET status = 'CANCELLED'
    WHERE subscription_id = p_subscription_id;

    DBMS_OUTPUT.PUT_LINE('Subscription Cancelled');
END;
/

BEGIN
    cancel_subscription(1);
END;
/

